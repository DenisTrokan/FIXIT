# =============================================================================
# FIXIT crontab — example entries
#
# Install with:
#   sudo crontab -u fixit -e
# or append to the system crontab:
#   sudo cp /opt/fixit/crontab.example /etc/cron.d/fixit
#   (then remove the "crontab -u" prefix and set user in the 6th field)
# =============================================================================

# --- Watchdog: check every 5 minutes if FIXIT is running; start it if not ---
*/5 * * * * /opt/fixit/scripts/check_and_start.sh >> /var/log/fixit/cron.log 2>&1

# --- Daily log rotation (logrotate handles it, but this is a safety net) ---
# 0 0 * * * find /var/log/fixit -name "*.log" -mtime +30 -delete

# --- Example: Zabbix SNMP heartbeat trap every minute ---
# * * * * * /opt/fixit/scripts/snmp_trap.sh heartbeat >> /var/log/fixit/snmp.log 2>&1
