# Flask Configuration
SECRET_KEY=genera-una-chiave-casuale-lunga-qui
FLASK_ENV=production

# Genera SECRET_KEY con: python -c "import secrets; print(secrets.token_hex(32))"

# Password dell'utente admin iniziale (obbligatorio al primo avvio)
# Genera con: python -c "import secrets; print(secrets.token_urlsafe(16))"
ADMIN_PASSWORD=cambia-questa-password-sicura

# Sicurezza sessioni (True in produzione con HTTPS, False per sviluppo locale senza HTTPS)
SESSION_COOKIE_SECURE=True

# Rate limiting storage (usa Redis in produzione multi-worker per contatori condivisi)
# RATELIMIT_STORAGE_URI=redis://localhost:6379
